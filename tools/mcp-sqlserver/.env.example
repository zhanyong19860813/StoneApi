# 复制为 .env 后改成本机测试库（勿提交 .env）

# 方式一：完整连接串（推荐）
SQLSERVER_CONNECTION_STRING=Server=127.0.0.1,1433;Database=SJHRsalarySystemDb;User Id=sa;Password=123456;Encrypt=true;TrustServerCertificate=true

# 方式二：分项（与连接串二选一）
# SQLSERVER_SERVER=127.0.0.1
# SQLSERVER_PORT=1433
# SQLSERVER_DATABASE=YourTestDb
# SQLSERVER_USER=sa
# SQLSERVER_PASSWORD=***
# SQLSERVER_ENCRYPT=true
# SQLSERVER_TRUST_CERT=true
