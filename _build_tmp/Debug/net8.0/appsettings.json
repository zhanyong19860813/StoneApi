{
  // ---------- 日志 ----------
  "Logging": {
    // 日志级别配置（子项可覆盖父级）
    "LogLevel": {
      // 未单独指定的命名空间默认使用 Information
      "Default": "Information",
      // ASP.NET Core 框架自身日志降为 Warning，减少控制台噪音
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // 允许的主机头；* 表示不限制（生产环境可按域名收紧）
  "AllowedHosts": "*",

  // 是否在非 Development 环境也启用 Swagger UI（本机/内网演示可 true；公网生产建议 false）
  "EnableSwaggerInProduction": true,

  // 是否启用 HTTP→HTTPS 重定向；仅 HTTP 部署（如直接 Kestrel/exe）请 false；IIS 已配 SSL 时可 true
  "EnableHttpsRedirection": false,

  // ---------- 数据库 ----------
  // SqlSugar SQL 命令超时（秒）；低配服务器慢查询可调大，如 180/240
  "SqlCommandTimeoutSeconds": 180,
  "ConnectionStrings": {
    // SqlSugar / 业务库默认连接串（服务器、库名、账号密码按实际环境修改）
    "DefaultConnection": "Server=localhost;Database=StoneDb;User Id=sa;Password=123456;TrustServerCertificate=true;"
  },

  // ---------- JWT 令牌 ----------
  "JwtSettings": {
    // 签名密钥（须足够长且保密；生产务必更换为强随机串并勿提交到公开仓库）
    "Secret": "StoneApi_JWT_Secret_Key_2026_Auth_System_32Chars",
    // 签发者（iss），签发 token 时写入，校验时需一致
    "Issuer": "YourCompany",
    // 受众（aud），同上
    "Audience": "YourApp",
    // 访问令牌有效分钟数
    "AccessTokenExpirationMinutes": 50,
    // 刷新令牌有效天数（若业务启用刷新逻辑时使用）
    "RefreshTokenExpirationDays": 30
  }
}
